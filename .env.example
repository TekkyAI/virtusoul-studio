# Database
DATABASE_URL=postgresql://studio:studio@localhost:5432/openclaw_studio

# Auth
ADMIN_PASSWORD=changeme
SESSION_SECRET=replace-with-random-64-char-string

# OpenClaw Gateway
GATEWAY_URL=ws://localhost:18789
GATEWAY_AUTH_TOKEN=your-gateway-auth-token

# Server
API_PORT=5181

# SSL — Option A: Built-in HTTPS (custom certs)
# SSL_CERT=/path/to/cert.pem
# SSL_KEY=/path/to/key.pem

# SSL — Option B: Caddy auto-SSL (Let's Encrypt)
# Set DOMAIN and run: docker compose --profile ssl up -d
# DOMAIN=studio.yourdomain.com
